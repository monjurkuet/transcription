# Required
SERVICE_API_KEY=change-me
DATABASE_URL=postgresql://username:password@localhost:5432/audio_transcript
GROQ_API_KEYS=gsk_key_1,gsk_key_2

# Optional providers
MISTRAL_API_KEYS=
GROQ_MODEL=whisper-large-v3
MISTRAL_MODEL=voxtral-mini-latest

# Optional infrastructure
REDIS_URL=redis://127.0.0.1:6379/0
QUEUE_NAME=audio-transcript:jobs
STORAGE_ROOT=./data
TRANSCRIPT_DATASET_ROOT=./transcript_dataset

# Optional processing
REQUEST_TIMEOUT_SEC=300
PROVIDER_MAX_RETRIES=3
CHUNK_DURATION_SEC=600
CHUNK_OVERLAP_SEC=5
MAX_FILE_SIZE_MB=25
MAX_PARALLEL_CHUNKS=3
JOB_RETENTION_DAYS=7

# Optional database pool
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10
DB_POOL_TIMEOUT_SEC=30

# Optional whisper.cpp fallback
WHISPER_CPP_BASE_URL=http://127.0.0.1:8334
WHISPER_CPP_MODEL_PATH=
WHISPER_CPP_TEMPERATURE=0.0
WHISPER_CPP_TEMPERATURE_INC=0.2
DYNAMIC_WHISPER_CPP_LOAD=false

# Optional logging
LOG_LEVEL=INFO
LOG_FORMAT=text
